# ===== Build args =====
# Hermes 上游 git ref —— 接受 commit sha / tag / branch
# 完整 sha 最稳；服务器当前 host 安装版本是 v2026.4.23 之上的一个 commit
HERMES_VERSION=853ed609a1a4ac056e810d7d3172c71517762420

# 镜像 tag（推到 registry 时用）
HERMES_TAG=latest

# ===== Runtime: 用户 UID/GID 重映射 =====
# 设成 host 上拥有 ~/.hermes 目录的用户
# 服务器: 1000 (admin)
# Mac:    $(id -u) / $(id -g)
HERMES_UID=1000
HERMES_GID=1000

# ===== Volume bind paths =====
# Hermes 数据目录（持久化）
# 服务器: /home/admin/.hermes  ← 沿用现有数据
# Mac:    /Users/<you>/.ailab-hermes  ← 首次启动会建模板
HERMES_HOST_DATA=/home/admin/.hermes

# ===== Hermes ↔ Django 内部 token =====
# 必须和 backend/.env 中 HERMES_INTERNAL_TOKEN 完全一致
# 当前服务器值在旧 systemd unit 里：
#   /home/admin/.config/systemd/user/hermes-gateway.service
HERMES_INTERNAL_TOKEN=__SET_ME__

# ===== Hermes API key（前端走 nginx → /hermes 时用）=====
# 写在这里只为 healthcheck 用（curl /api/tools 需要 Bearer）
# 当前值见 frontend/src/config/api.js HERMES_API_KEY
HERMES_API_KEY=ailab-hermes-2026

# ===== Build args =====
# Hermes 上游 git ref —— 接受 commit sha / tag / branch
# 完整 sha 最稳；服务器当前 host 安装版本是 v2026.4.23 之上的一个 commit
HERMES_VERSION=853ed609a1a4ac056e810d7d3172c71517762420

# 镜像 tag（推到 registry 时用）
HERMES_TAG=latest

# ===== Runtime: 用户 UID/GID 重映射 =====
# 设成 host 上拥有 ~/.hermes 目录的用户
# 服务器: 1000 (admin)
# Mac:    $(id -u) / $(id -g)
HERMES_UID=1000
HERMES_GID=1000

# ===== Volume bind paths — 每用户独立 Hermes 数据目录 =====
# 对应 Django user id，与 docker-compose.yml / nginx.conf / HERMES_USER_CONTAINERS_JSON 同步
HERMES_U3_DATA=/home/admin/hermes-users/user3
HERMES_U9_DATA=/home/admin/hermes-users/user9
HERMES_U550_DATA=/home/admin/hermes-users/user550

# ===== Django 容器映射 JSON =====
# key 是 Django user id，value 包含 port（宿主机端口）和 data_dir（bind mount 路径）
# 必须与 docker-compose.yml 中的端口、nginx.conf 中的 location 同步
HERMES_USER_CONTAINERS_JSON={"3":{"port":8642,"data_dir":"/home/admin/hermes-users/user3"},"9":{"port":8643,"data_dir":"/home/admin/hermes-users/user9"},"550":{"port":8644,"data_dir":"/home/admin/hermes-users/user550"}}

# ===== Hermes ↔ Django 内部 token =====
# 必须和 backend/.env 中 HERMES_INTERNAL_TOKEN 完全一致
# 当前服务器值在旧 systemd unit 里：
#   /home/admin/.config/systemd/user/hermes-gateway.service
HERMES_INTERNAL_TOKEN=__SET_ME__

# ===== Hermes API key（前端走 nginx → /hermes 时用）=====
# 写在这里只为 healthcheck 用（curl /api/tools 需要 Bearer）
# 当前值见 frontend/src/config/api.js HERMES_API_KEY
HERMES_API_KEY=ailab-hermes-2026

# ===== 共享 owner 的 ~/.hermes/{.env,config.yaml}（临时方案 A）=====
# 三个用户容器都挂载这两个只读文件，所以三个用户共享：
#   - .env       —— LLM provider API keys（OPENROUTER_API_KEY, DEEPSEEK_API_KEY, ...）
#   - config.yaml —— model 选择（default model / provider）、agent 行为、MCP 等
# u9 / u550 也走 owner 的 LLM 配额和 model 选择。sessions/state.db 仍 per-user。
# 等 per-user 凭证 + 配置就位后，把各自的 .env / config.yaml 放到
# hermes-users/userX/.hermes/ 下，并删掉 docker-compose.yml 里的这两条挂载。
HERMES_OWNER_ENV=/home/admin/.hermes/.env
HERMES_OWNER_CONFIG=/home/admin/.hermes/config.yaml

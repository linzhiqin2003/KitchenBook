# syntax=docker/dockerfile:1.7
#
# ailab Hermes Agent — containerized build
#
# 策略：把 host 上当前能跑的 ~/.hermes/hermes-agent (已 patched) snapshot 进镜像。
# 不在容器里 clone upstream + apply patch —— 因为 patches 跟上游会逐渐脱节
# (anchor drift)。host 模式下 apply.sh 已经把状态固化，我们直接照搬。
#
# 部署前必须先跑：bash deploy/docker/prepare-source.sh
# 它把 ~/.hermes/hermes-agent 用 rsync 拷到 _hermes_source/，排除
# venv / node_modules / .git / *.bak / __pycache__。
#
# 阶段：
#   1. uv_source / gosu_source : 拉静态二进制
#   2. runtime                 : Debian + node + python，COPY snapshot，
#                                npm install + uv pip install
#
# 关键差异 vs 上游 Dockerfile：
#   - source 来自 host snapshot（不是 git clone）
#   - 不装 Playwright chromium (PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1)
#   - 不装 docker-cli (防容器内 docker socket 逃逸)

# ============================================================
# Stage 1: 静态二进制工具 (uv / gosu)
# ============================================================
FROM ghcr.io/astral-sh/uv:0.11.6-python3.13-trixie AS uv_source
FROM tianon/gosu:1.19-trixie AS gosu_source

# ============================================================
# Stage 2: runtime
# ============================================================
FROM debian:13.4

ENV PYTHONUNBUFFERED=1
# 跳过 Playwright 浏览器下载（npm install 时也不会拉 chromium）
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
ENV PLAYWRIGHT_SKIP_VALIDATE_HOST_REQUIREMENTS=1

# 系统依赖（vs 上游：去掉 docker-cli）
# tini: PID1 收割 MCP/git/bun 等子进程僵尸
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential nodejs npm python3 python3-yaml ripgrep ffmpeg gcc \
        python3-dev libffi-dev procps git openssh-client tini ca-certificates \
        curl jq && \
    rm -rf /var/lib/apt/lists/*

# 非 root 用户（runtime UID 在 entrypoint 里通过 HERMES_UID 重映射）
RUN useradd -u 10000 -m -d /opt/data hermes

COPY --chmod=0755 --from=gosu_source /gosu /usr/local/bin/
COPY --chmod=0755 --from=uv_source /usr/local/bin/uv /usr/local/bin/uvx /usr/local/bin/

WORKDIR /opt/hermes

# ---------- Source snapshot from host ----------
# 来源：deploy/docker/_hermes_source/（由 prepare-source.sh 生成）
# 这份源码已经包含 host 上 apply.sh 的 17 个 patch 改动 + tiktoken 等
COPY --chown=hermes:hermes deploy/docker/_hermes_source/ /opt/hermes/

# ---------- npm 依赖（仅在需要 dashboard 时启用） ----------
# Hermes gateway (OpenAI-compatible API server) 本身不需要 web / ui-tui 的
# dashboard build，那是给 hermes dashboard / TUI 用的。当前 ailab 用例只走
# /v1/chat/completions + /api/tools，跳过 npm 阶段。如果未来要用 dashboard,
# 把下面这段重新启用（注意新加坡 server 到 npmjs/npmmirror 都不稳，可能要
# 先在 host 上 npm install + npm run build，再把 web/dist + ui-tui/dist 包进
# prepare-source.sh 的 rsync 范围）。
#
# RUN npm config set registry https://registry.npmmirror.com && \
#     npm config set fetch-timeout 600000 && \
#     npm install --prefer-offline --no-audit && \
#     (cd web && npm install && npm run build) && \
#     (cd ui-tui && npm install && npm run build) && \
#     npm cache clean --force

# ---------- Python venv ----------
USER root
RUN chmod -R a+rX /opt/hermes && \
    uv venv && \
    uv pip install --no-cache-dir -e ".[all]" && \
    uv pip install --no-cache-dir 'tiktoken>=0.7.0,<1'

# ---------- runtime env ----------
ENV HERMES_WEB_DIST=/opt/hermes/hermes_cli/web_dist
ENV HERMES_HOME=/opt/data
ENV PATH="/opt/data/.local/bin:${PATH}"
VOLUME ["/opt/data"]

EXPOSE 8642

# 上游 entrypoint 处理 gosu / 用户重映射 / 模板 cp
ENTRYPOINT ["/usr/bin/tini", "-g", "--", "/opt/hermes/docker/entrypoint.sh"]
CMD ["gateway", "run"]
